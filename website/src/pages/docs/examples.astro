---
import DocsLayout from '../../layouts/DocsLayout.astro';
import CodeBlock from '../../components/CodeBlock.astro';

const examples = [
  {
    title: 'OG Card',
    desc: 'A blog post Open Graph image with gradient background, tag badge, title, author avatar, and accent stripe.',
    img: '/examples/og-card.png',
    file: 'og-card.tsx',
    cmd: 'npx grafex export -f og-card.tsx -o og-card.png',
  },
  {
    title: 'Social Media Card',
    desc: 'A Twitter/LinkedIn quote card with avatar, quote text, engagement stats, and branding.',
    img: '/examples/social-card.png',
    file: 'social-card.tsx',
    cmd: 'npx grafex export -f social-card.tsx -o social-card.png',
  },
  {
    title: 'Email Banner',
    desc: 'A promotional banner with bold typography, discount callout, and call-to-action button.',
    img: '/examples/banner.png',
    file: 'banner.tsx',
    cmd: 'npx grafex export -f banner.tsx -o banner.png',
  },
  {
    title: 'Certificate',
    desc: 'A completion certificate with decorative border, recipient name, course details, and signatures.',
    img: '/examples/certificate.png',
    file: 'certificate.tsx',
    cmd: 'npx grafex export -f certificate.tsx -o certificate.png',
  },
  {
    title: 'Video Thumbnail',
    desc: 'A YouTube-style thumbnail with episode badge, bold title, tech tags, and channel branding.',
    img: '/examples/thumbnail.png',
    file: 'thumbnail.tsx',
    cmd: 'npx grafex export -f thumbnail.tsx -o thumbnail.png',
  },
  {
    title: 'Architecture Diagram',
    desc: 'A technical diagram showing client, API, and database with connection arrows and protocol labels.',
    img: '/examples/diagram.png',
    file: 'diagram.tsx',
    cmd: 'npx grafex export -f diagram.tsx -o diagram.png',
  },
];

// Read all example source files
import { readFileSync } from 'node:fs';
import { resolve } from 'node:path';

const exampleDir = resolve(process.cwd(), 'examples');
const sources = Object.fromEntries(
  ['og-card-example.tsx', 'social-card-example.tsx', 'banner-example.tsx', 'certificate-example.tsx', 'thumbnail-example.tsx', 'diagram-example.tsx']
    .map((f, i) => [examples[i].file, readFileSync(resolve(exampleDir, f), 'utf-8')])
);
---

<DocsLayout title="Examples" currentPage="/docs/examples" description="Real compositions you can copy, modify, and render.">
  <div class="max-w-4xl">
    <h1 class="font-heading text-4xl font-bold mb-4 text-heading">Examples</h1>
    <p class="text-lg mb-12 text-body">
      Real compositions you can copy, modify, and render. Each example shows the rendered output and the full source code.
    </p>

    <div class="space-y-16">
      {examples.map((ex) => (
        <div>
          <h2 class="font-heading text-2xl font-semibold mb-2 text-heading">{ex.title}</h2>
          <p class="text-base mb-4 text-body">{ex.desc}</p>

          {/* Rendered image */}
          <div class="checkerboard rounded-xl overflow-hidden border mb-4 flex items-center justify-center p-4 border-edge">
            <img src={ex.img} alt={ex.title} class="block rounded-lg w-full max-w-[600px]" loading="lazy" />
          </div>

          {/* CLI command */}
          <CodeBlock lang="bash" code={ex.cmd} />

          {/* Collapsible source */}
          <CodeBlock collapsible lang="tsx" label={ex.file} code={sources[ex.file]} maxHeight="400px" />
        </div>
      ))}
    </div>
  </div>
</DocsLayout>
