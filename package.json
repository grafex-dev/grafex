{
  "name": "grafex",
  "version": "0.1.0",
  "type": "module",
  "description": "Images as Code. Write JSX, export PNG.",
  "bin": {
    "grafex": "./dist/cli.js"
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup src/index.ts src/cli.ts --format esm --dts",
    "dev": "tsup src/index.ts src/cli.ts --format esm --dts --watch",
    "test": "vitest",
    "prepublishOnly": "npm run build",
    "postinstall": "npx playwright install webkit || true"
  },
  "dependencies": {
    "esbuild": "^0.24.0",
    "playwright-core": "^1.49.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "prettier": "^3.4.0",
    "tsup": "^8.3.0",
    "typescript": "^5.7.0",
    "vitest": "^2.1.0"
  },
  "engines": {
    "node": ">=18.3.0"
  }
}
